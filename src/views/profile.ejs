<!DOCTYPE html>
<html>
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white text-center"><h4>👤 User Profile</h4></div>
                    <div class="card-body p-4 text-center">
                        <p class="mb-1 text-muted">User ID</p>
                        <h5 class="mb-4"><%= user.userId %></h5>
                        <p class="mb-1 text-muted">Email Address</p>
                        <h5 class="text-primary"><%= user.email %></h5>
                        <hr>
                        <div class="d-flex justify-content-between">
                            <a href="/" class="btn btn-outline-secondary">Back Home</a>
                            <form method="POST" action="/logout"><button class="btn btn-danger">Logout</button></form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>