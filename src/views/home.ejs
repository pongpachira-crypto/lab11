<!DOCTYPE html>
<html>
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>body { background: #f4f7f6; font-family: 'Segoe UI', sans-serif; }</style>
</head>
<body class="d-flex align-items-center vh-100">
    <div class="container text-center">
        <div class="card shadow-sm p-5 mx-auto" style="max-width: 600px;">
            <h1 class="mb-4">🏠 Home</h1>
            <% if (isLoggedIn) { %>
                <div class="alert alert-info">You are currently signed in.</div>
                <div class="d-grid gap-2">
                    <a href="/profile" class="btn btn-primary">Go to Profile</a>
                    <form action="/logout" method="POST"><button class="btn btn-outline-danger w-100">Logout</button></form>
                </div>
            <% } else { %>
                <p class="text-muted">Please log in to access your protected profile.</p>
                <a href="/login" class="btn btn-dark btn-lg">Login / Register</a>
            <% } %>
        </div>
    </div>
</body>
</html>