<!DOCTYPE html>
<html>
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow p-4">
                    <h2 class="text-center mb-4">🔐 Login</h2>
                    
                    <% if (query.err) { %><div class="alert alert-danger text-center">Invalid email or password</div><% } %>
                    <% if (query.msg === 'registered') { %><div class="alert alert-success text-center">Account created! Please login.</div><% } %>
                    <% if (query.msg === 'logout') { %><div class="alert alert-primary text-center">Successfully logged out.</div><% } %>

                    <form method="POST" action="/login">
                        <div class="mb-3"><input name="email" class="form-control" type="email" placeholder="Email" required></div>
                        <div class="mb-3"><input name="password" class="form-control" type="password" placeholder="Password" required></div>
                        <button type="submit" class="btn btn-primary w-100">Login</button>
                    </form>

                    <hr class="my-4">
                    <p class="text-center text-muted small">Need a test account?</p>
                    <form method="POST" action="/register">
                        <div class="mb-2"><input name="email" class="form-control form-control-sm" placeholder="New Email" required></div>
                        <div class="mb-2"><input name="password" class="form-control form-control-sm" type="password" placeholder="New Password" required></div>
                        <button type="submit" class="btn btn-outline-secondary btn-sm w-100">Register</button>
                    </form>
                </div>
                <div class="text-center mt-3"><a href="/" class="text-decoration-none text-secondary">← Back to Home</a></div>
            </div>
        </div>
    </div>
</body>
</html>